.idea/
.aider*
__pycache__/
*.pyc

# Stray application log dumps — never belong in this repo.
*.log
logs.txt

# Ignore everything in secrets/ by default (plaintext creds live here),
# allow only sops-encrypted files which are safe to commit.
secrets/*
!secrets/secrets.yaml
!secrets/vnc.yaml
!secrets/kpass.yaml
# ssh host configs split by context (re-include the subdir, then its files)
!secrets/ssh/
!secrets/ssh/*.yaml
keys.txt

# nix build output symlinks (system/home closures) — never belong in this repo.
result
result-*

# git-hooks.nix generates this on devShell entry
.pre-commit-config.yaml

# direnv local cache (nix-direnv profile links)
.direnv/
.claude/

# local MCP server config — may hold tokens, never commit
.mcp.json
