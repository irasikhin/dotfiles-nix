set $mod Mod4
set $alt Mod1
set $terminal foot
set $launcher fuzzel
set $window_switcher swaymsg -t get_tree | jq -r '.. | select(.type?) | select(.focused==false) | select(.name!=null) | "\(.app_id // .window_properties.class) — \(.name)"' | fuzzel --dmenu -p "window: "
set $lock_cmd $HOME/dotfiles-nix/home-manager/dotfiles/scripts/lock_screen.sh

font pango:Fira Code 9
floating_modifier $mod

input "type:keyboard" {
    xkb_layout "us,ru"
    xkb_options "grp:shifts_toggle"
}
# Kensington ORBIT trackball: too jerky, so flatten accel and slow it down.
input "1149:32936:ORBIT_BT5.0_Mouse" {
    accel_profile flat
    pointer_accel -0.6
}
# Dedicated layout switch for the split (BCORNE): map a free key to F24 in Vial.
# Avoids grp:ctrl_shift_toggle, which collided with terminal Ctrl+Shift+C/V.
bindsym --to-code F24 input "type:keyboard" xkb_switch_layout next
# External monitor: global GDK_DPI_SCALE/Xft.dpi are tuned for the HiDPI laptop
# panel, so the BenQ 1080p renders oversized. Scale it down. Keyed by the output
# identifier (make/model/serial), so it applies over both HDMI and DP.
output "BNQ ZOWIE XL LCD EBN3N01670SL0" scale 0.9

default_border none
default_floating_border none
titlebar_border_thickness 0
titlebar_padding 4 2

bindsym --to-code $mod+Return exec $terminal
bindsym --to-code $alt+d exec $launcher
bindsym --to-code $mod+Tab exec $window_switcher

bindsym --to-code $alt+v exec cliphist list | fuzzel --dmenu -p "clipboard: " | cliphist decode | wl-copy
bindsym --to-code $alt+p exec echo -e "lock\nlogout\nsuspend\nreboot\nshutdown" | fuzzel --dmenu -p "power: " | xargs -I {} sh -c 'case {} in lock) $lock_cmd;; logout) swaymsg exit;; suspend) systemctl suspend;; reboot) systemctl reboot;; shutdown) systemctl poweroff;; esac'

# Screenshots (grim -> satty annotation editor; Ctrl+S in satty saves to ~/Pictures/Screenshots, Ctrl+C copies).
# Print          -> select region, open editor
# Shift+Print    -> whole focused output, open editor
# Ctrl+Print     -> select region straight to clipboard, no editor
set $satty satty -f - --copy-command wl-copy --output-filename "$HOME/Pictures/Screenshots/$(date +%Y%m%d-%H%M%S).png"
bindsym Print exec grim -g "$(slurp -d)" - | $satty
bindsym Shift+Print exec grim -o "$(swaymsg -t get_outputs | jq -r '.[] | select(.focused).name')" - | $satty
bindsym Ctrl+Print exec grim -g "$(slurp -d)" - | wl-copy

bindsym --to-code $mod+Shift+q kill
bindsym --to-code $mod+Shift+a focus parent, kill
bindsym --to-code $mod+Ctrl+Shift+q exec $HOME/.config/scripts/killapp.sh

bindsym --to-code $mod+j focus left
bindsym --to-code $mod+k focus down
bindsym --to-code $mod+l focus up
bindsym --to-code $mod+semicolon focus right

bindsym --to-code $mod+Left focus left
bindsym --to-code $mod+Down focus down
bindsym --to-code $mod+Up focus up
bindsym --to-code $mod+Right focus right

bindsym --to-code $mod+Shift+j move left
bindsym --to-code $mod+Shift+k move down
bindsym --to-code $mod+Shift+l move up
bindsym --to-code $mod+Shift+semicolon move right

bindsym --to-code $mod+Shift+Left move left
bindsym --to-code $mod+Shift+Down move down
bindsym --to-code $mod+Shift+Up move up
bindsym --to-code $mod+Shift+Right move right

bindsym --to-code $mod+h split h
bindsym --to-code $mod+v split v

bindsym --to-code $mod+f fullscreen toggle

bindsym --to-code $mod+s layout stacking
bindsym --to-code $mod+w layout tabbed
bindsym --to-code $mod+e layout toggle split

bindsym --to-code $mod+Shift+space floating toggle
bindsym --to-code $mod+space focus mode_toggle

bindsym --to-code $mod+a focus parent

bindsym --to-code $mod+n exec swaync-client -t -sw
bindsym --to-code $mod+Shift+n exec swaync-client -C
bindsym --to-code $mod+Shift+c reload
bindsym --to-code $mod+Shift+r reload
bindsym --to-code $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit Sway? This will end your session.' -B 'Yes, exit Sway' 'swaymsg exit'
bindsym --to-code $mod+Shift+w exec $lock_cmd

bindsym --to-code $mod+r mode "resize"

mode "resize" {
    bindsym --to-code j resize shrink width 10 px or 10 ppt
    bindsym --to-code k resize grow height 10 px or 10 ppt
    bindsym --to-code l resize shrink height 10 px or 10 ppt
    bindsym --to-code semicolon resize grow width 10 px or 10 ppt

    bindsym --to-code Left resize shrink width 10 px or 10 ppt
    bindsym --to-code Down resize grow height 10 px or 10 ppt
    bindsym --to-code Up resize shrink height 10 px or 10 ppt
    bindsym --to-code Right resize grow width 10 px or 10 ppt

    bindsym --to-code Return mode "default"
    bindsym --to-code Escape mode "default"
    bindsym --to-code $mod+r mode "default"
}

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

set $ws_terminal "terminal"
set $ws_web "web"
set $ws_code "code"
set $ws_idea "idea"
set $ws_obsidian "obsidian"
set $ws_msg "msg"
set $ws_thunderbird "thunderbird"
set $ws_music "music"
set $ws_bruno "bruno"
set $ws_dbeaver "dbeaver"
set $ws_express "express"
set $ws_sysinfo "sysinfo"

bindsym --to-code $mod+1 workspace $ws1
bindsym --to-code $mod+2 workspace $ws2
bindsym --to-code $mod+3 workspace $ws3
bindsym --to-code $mod+4 workspace $ws4
bindsym --to-code $mod+5 workspace $ws5
bindsym --to-code $mod+6 workspace $ws6
bindsym --to-code $mod+7 workspace $ws7
bindsym --to-code $mod+8 workspace $ws8
bindsym --to-code $mod+9 workspace $ws9
bindsym --to-code $mod+0 workspace $ws10

bindsym --to-code $mod+u workspace $ws_web
bindsym --to-code $mod+c workspace $ws_code
bindsym --to-code $mod+i workspace $ws_idea
bindsym --to-code $mod+o workspace $ws_obsidian
bindsym --to-code $mod+m workspace $ws_msg
bindsym --to-code $mod+t workspace $ws_thunderbird
bindsym --to-code $mod+p workspace $ws_music
bindsym --to-code $mod+b workspace $ws_bruno
bindsym --to-code $mod+d workspace $ws_dbeaver
bindsym --to-code $mod+x workspace $ws_express
bindsym --to-code $mod+F12 workspace $ws_sysinfo

bindsym --to-code --release --no-repeat Super_L exec $HOME/.config/scripts/double_mod_switch.sh
# Split (BCORNE) only has a right Super (RGui); bind it too so double-tap works there.
bindsym --to-code --release --no-repeat Super_R exec $HOME/.config/scripts/double_mod_switch.sh

bindsym --to-code $mod+Shift+1 move container to workspace $ws1
bindsym --to-code $mod+Shift+2 move container to workspace $ws2
bindsym --to-code $mod+Shift+3 move container to workspace $ws3
bindsym --to-code $mod+Shift+4 move container to workspace $ws4
bindsym --to-code $mod+Shift+5 move container to workspace $ws5
bindsym --to-code $mod+Shift+6 move container to workspace $ws6
bindsym --to-code $mod+Shift+7 move container to workspace $ws7
bindsym --to-code $mod+Shift+8 move container to workspace $ws8
bindsym --to-code $mod+Shift+9 move container to workspace $ws9
bindsym --to-code $mod+Shift+0 move container to workspace $ws10

workspace_auto_back_and_forth yes
focus_on_window_activation focus

assign [app_id="foot"] $ws_terminal
assign [app_id="Alacritty"] $ws_terminal
assign [class="(?i)^Alacritty$"] $ws_terminal

assign [app_id="floorp"] $ws_web
assign [class="(?i)^(LibreWolf|Firefox|Chromium|Floorp|Google-chrome)$"] $ws_web

assign [app_id="code"] $ws_code
assign [class="(?i)^Code$"] $ws_code

assign [app_id="jetbrains-idea"] $ws_idea
assign [class="(?i)^jetbrains-idea"] $ws_idea

assign [app_id="obsidian"] $ws_obsidian
assign [class="(?i)^obsidian$"] $ws_obsidian

assign [app_id="org.telegram.desktop"] $ws_msg
assign [class="(?i)^TelegramDesktop$"] $ws_msg

assign [app_id="thunderbird"] $ws_thunderbird
assign [class="(?i)^thunderbird$"] $ws_thunderbird

assign [app_id="feishin"] $ws_music
assign [class="(?i)^feishin$"] $ws_music
assign [app_id="spotify"] $ws_music
assign [class="(?i)^spotify$"] $ws_music

assign [app_id="bruno"] $ws_bruno
assign [class="(?i)^Bruno$"] $ws_bruno

assign [app_id="dbeaver"] $ws_dbeaver
assign [class="(?i)^DBeaver$"] $ws_dbeaver

assign [app_id="eXpress_Corporate"] $ws_express
assign [class="(?i)^eXpress_Corporate$"] $ws_express

assign [app_id="sysinfo"] $ws_sysinfo

exec_always sh -c 'pkill -x .waybar-wrapped; sleep 0.3; waybar'
exec wl-paste --type text --watch cliphist store

bindsym XF86AudioRaiseVolume exec --no-startup-id pamixer -i 5
bindsym XF86AudioLowerVolume exec --no-startup-id pamixer -d 5
bindsym XF86AudioMute exec --no-startup-id pamixer -t

bindsym XF86MonBrightnessUp exec --no-startup-id brillo -A 5
bindsym XF86MonBrightnessDown exec --no-startup-id brillo -U 5

bindsym XF86AudioPlay exec playerctl play
bindsym XF86AudioPause exec playerctl pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

exec_always --no-startup-id dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP=sway
exec_always --no-startup-id systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
exec_always --no-startup-id nm-applet --indicator
exec_always --no-startup-id $HOME/.config/scripts/update_background_image.sh
exec_always --no-startup-id sh -c 'pkill -x swayidle; exec swayidle -w timeout 900 "$1" before-sleep "$1"' _ "$lock_cmd"

# Single-display: external connected -> internal eDP-1 off; no external ->
# eDP-1 on. Reacts to hotplug, keeps exactly one screen.
exec_always --no-startup-id $HOME/.config/scripts/single_display.sh

exec --no-startup-id $terminal
exec --no-startup-id floorp
exec --no-startup-id idea
exec --no-startup-id telegram-desktop
exec --no-startup-id thunderbird
exec --no-startup-id feishin

# System info screen on its own workspace (live-refreshing fastfetch)
exec --no-startup-id foot --app-id=sysinfo -e watch -ctn 2 fastfetch

# Don't leave empty workspace 1 on startup — focus terminal
exec --no-startup-id swaymsg workspace $ws_terminal
