DEFAULT_DB_PATH = os.path.expanduser("~/.keepass/keepass.kdbx")
DEFAULT_CLIPBOARD_TIMEOUT = 10
DEFAULT_CACHE_TTL = 300
DEFAULT_CONFIG_PATH = "~/.config/kpass/config.toml"
LARGE_ATTACHMENT_WARNING_BYTES = 5 * 1024 * 1024
PROFILE_CONFIG_KEYS = {
    "database",
    "password_file",
    "password_database",
    "password_entry",
    "key_file",
    "session_ttl",
    "cache_ttl",
    "no_session",
    "no_cache",
}
TOP_LEVEL_CONFIG_KEYS = {"default", "databases"}
GLOBAL_OPTIONS_WITH_VALUES = {
    "--config",
    "--database",
    "--password-file",
    "--key-file",
    "--session-ttl",
    "--cache-ttl",
}
COMMANDS_WITH_DATABASE = {
    "ls",
    "search",
    "get",
    "copy",
    "attach",
    "pick",
    "insert",
    "edit",
    "remove",
    "move",
