SEARCH_FIELD_CHOICES = ENTRY_FIELD_CHOICES


class KPassError(Exception):
    pass


class MatchError(KPassError):
    pass


class KPassArgumentParser(argparse.ArgumentParser):
    def error(self, message: str) -> None:
        raise KPassError(f"{self.prog}: {message}\nUse '{self.prog} --help' for usage.")


@dataclass
class Config:
    database: str
    password_file: str | None
    password: str | None
    key_file: str | None
    cache_ttl: int
    no_cache: bool


@dataclass(frozen=True)
class DatabaseProfile:
    database: str
    password_file: str | None = None
    password_database: str | None = None
    password_entry: str | None = None
    key_file: str | None = None
    cache_ttl: int | None = None
    no_cache: bool | None = None


@dataclass(frozen=True)
class FileConfig:
    default_database: str | None = None
    databases: dict[str, DatabaseProfile] = field(default_factory=dict)


EDITABLE_ENTRY_FIELDS = ("title", "username", "password", "url", "otp")


def normalize_path(value: str) -> str:
    return value.strip().strip("/")


def expand_path(value: str | None) -> str | None:
    if value is None:
        return None
    return os.path.expanduser(value)


def config_file_path(explicit_path: str | None = None) -> Path:
    configured = explicit_path or os.environ.get("KPASS_CONFIG") or DEFAULT_CONFIG_PATH
    return Path(configured).expanduser()


def toml_quote(value: str) -> str:
    return json.dumps(value)


def toml_key(key: str) -> str:
    if key.replace("-", "_").isalnum() and key[0].isalpha():
        return key
    return toml_quote(key)


def parse_database_profile(name: str, data: object, path: Path) -> DatabaseProfile:
    if not isinstance(data, dict):
        raise KPassError(f"KPass database profile '{name}' must be a TOML table: {path}")

    unknown_keys = sorted(key for key in data.keys() if key not in PROFILE_CONFIG_KEYS)
    if unknown_keys:
        raise KPassError(f"Unsupported KPass config key(s) in profile '{name}': {', '.join(unknown_keys)}")

    database = data.get("database")
    if not isinstance(database, str) or not database.strip():
        raise KPassError(f"KPass database profile '{name}' must define a non-empty 'database' path.")

    cache_ttl = data.get("session_ttl", data.get("cache_ttl"))
    no_cache = data.get("no_session", data.get("no_cache"))

    if cache_ttl is not None and not isinstance(cache_ttl, int):
        raise KPassError(f"KPass config key 'session_ttl' in profile '{name}' must be an integer.")
    if no_cache is not None and not isinstance(no_cache, bool):
        raise KPassError(f"KPass config key 'no_session' in profile '{name}' must be a boolean.")

    for key in ("password_file", "key_file"):
        value = data.get(key)
        if value is not None and not isinstance(value, str):
            raise KPassError(f"KPass config key '{key}' in profile '{name}' must be a string.")
    for key in ("password_database", "password_entry"):
        value = data.get(key)
        if value is not None and not isinstance(value, str):
            raise KPassError(f"KPass config key '{key}' in profile '{name}' must be a string.")

    password_file = expand_path(data.get("password_file"))
    password_database = data.get("password_database")
    password_entry = data.get("password_entry")
    if password_file and (password_database or password_entry):
        raise KPassError(f"KPass database profile '{name}' cannot combine 'password_file' with password lookup from another database.")
    if (password_database is None) != (password_entry is None):
        raise KPassError(f"KPass database profile '{name}' must set both 'password_database' and 'password_entry' together.")

    return DatabaseProfile(
        database=expand_path(database) or database,
        password_file=password_file,
        password_database=password_database,
        password_entry=password_entry,
        key_file=expand_path(data.get("key_file")),
        cache_ttl=cache_ttl,
        no_cache=no_cache,
    )


def load_file_config(explicit_path: str | None = None) -> tuple[FileConfig, Path]:
    path = config_file_path(explicit_path)
    if not path.exists():
        return FileConfig(), path
    if not path.is_file():
        raise KPassError(f"KPass config path is not a file: {path}")

    try:
        data = tomllib.loads(path.read_text(encoding="utf-8"))
    except tomllib.TOMLDecodeError as exc:
        raise KPassError(f"Failed to parse KPass config {path}: {exc}") from exc

    if not isinstance(data, dict):
        raise KPassError(f"KPass config must be a TOML table: {path}")

    unknown_keys = sorted(key for key in data.keys() if key not in TOP_LEVEL_CONFIG_KEYS)
    if unknown_keys:
        raise KPassError(f"Unsupported KPass config key(s): {', '.join(unknown_keys)}")

    default_database = data.get("default")
    if not isinstance(default_database, str) or not default_database.strip():
        raise KPassError("KPass config must define a non-empty top-level 'default' database profile name.")

    databases_data = data.get("databases")
    if not isinstance(databases_data, dict) or not databases_data:
        raise KPassError("KPass config must define at least one [databases.<name>] profile.")

    databases = {
        name: parse_database_profile(name, profile_data, path)
        for name, profile_data in sorted(databases_data.items())
    }
    if default_database not in databases:
        raise KPassError(f"Default database profile not found: {default_database}")

    return (
        FileConfig(
            default_database=default_database,
            databases=databases,
        ),
        path,
    )


def env_cache_ttl() -> int | None:
    raw_value = os.environ.get("KPASS_SESSION_TTL", os.environ.get("KPASS_CACHE_TTL"))
    if raw_value is None:
        return None
    try:
        return int(raw_value)
    except ValueError as exc:
        raise KPassError("KPASS_SESSION_TTL must be an integer.") from exc


def dump_file_config(file_config: FileConfig) -> str:
    if not file_config.default_database:
        raise KPassError("KPass config must define a default database profile name.")
    if not file_config.databases:
        raise KPassError("KPass config must define at least one [databases.<name>] profile.")

    lines = [f"default = {toml_quote(file_config.default_database)}", ""]
    for profile_name in sorted(file_config.databases):
        profile = file_config.databases[profile_name]
        lines.append(f"[databases.{toml_key(profile_name)}]")
        lines.append(f"database = {toml_quote(profile.database)}")
        if profile.password_file is not None:
            lines.append(f"password_file = {toml_quote(profile.password_file)}")
        if profile.password_database is not None:
            lines.append(f"password_database = {toml_quote(profile.password_database)}")
        if profile.password_entry is not None:
            lines.append(f"password_entry = {toml_quote(profile.password_entry)}")
        if profile.key_file is not None:
            lines.append(f"key_file = {toml_quote(profile.key_file)}")
        if profile.cache_ttl is not None:
            lines.append(f"session_ttl = {profile.cache_ttl}")
        if profile.no_cache is not None:
            lines.append(f"no_session = {'true' if profile.no_cache else 'false'}")
        lines.append("")
    return "\n".join(lines)


def write_file_config(path: Path, file_config: FileConfig) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(dump_file_config(file_config), encoding="utf-8")


def extract_command_and_selector(argv: list[str]) -> tuple[list[str], str | None, str | None]:
    command_index: int | None = None
    index = 0

    while index < len(argv):
        token = argv[index]
        if token == "--":
            break
        if token in GLOBAL_OPTIONS_WITH_VALUES:
            index += 2
            continue
        if any(token.startswith(f"{option}=") for option in GLOBAL_OPTIONS_WITH_VALUES):
            index += 1
            continue
        if token.startswith("-"):
            index += 1
            continue
        command_index = index
        break

    if command_index is None:
        return argv, None, None

    command = argv[command_index]
    selector_index = command_index + 1
    if selector_index >= len(argv):
        return argv, command, None

    selector_token = argv[selector_index]
    if not selector_token.startswith("@"):
        return argv, command, None
    if selector_token == "@":
        raise KPassError("Database selector cannot be empty.")

    return argv[:selector_index] + argv[selector_index + 1 :], command, selector_token[1:]


def resolve_database_profile(file_config: FileConfig, selected_database: str | None) -> DatabaseProfile | None:
    if selected_database is not None:
        profile = file_config.databases.get(selected_database)
        if profile is None:
            raise KPassError(f"Unknown database profile: {selected_database}")
        return profile

    if file_config.databases:
        if file_config.default_database is None:
            raise KPassError("No default database configured.")
        return file_config.databases[file_config.default_database]

    return None


def config_from_profile(file_config: FileConfig, profile_name: str, resolving: tuple[str, ...] = ()) -> Config:
    if profile_name in resolving:
        loop = " -> ".join((*resolving, profile_name))
        raise KPassError(f"Database password resolution loop detected: {loop}")

    profile = file_config.databases.get(profile_name)
    if profile is None:
        raise KPassError(f"Unknown database profile: {profile_name}")

    resolved_password = None
    if profile.password_database and profile.password_entry:
        print(
            f"Using password for database profile '{profile_name}' from '{profile.password_database}:{profile.password_entry}'",
            file=sys.stderr,
        )
        source_config = config_from_profile(file_config, profile.password_database, (*resolving, profile_name))
        source_kp = open_database(source_config)
        entry = resolve_entry(source_kp, profile.password_entry)
        if not entry.password:
            raise KPassError(
                f"Password entry '{profile.password_entry}' in database profile '{profile.password_database}' does not contain a password."
            )
        resolved_password = entry.password

    return Config(
        database=profile.database,
        password_file=profile.password_file,
        password=resolved_password,
        key_file=profile.key_file,
        cache_ttl=profile.cache_ttl if profile.cache_ttl is not None else DEFAULT_CACHE_TTL,
        no_cache=bool(profile.no_cache),
    )


def resolve_runtime_config(args: argparse.Namespace, file_config: FileConfig, selected_database: str | None) -> Config:
    if selected_database is not None and args.command not in COMMANDS_WITH_DATABASE:
        raise KPassError(f"Command '{args.command}' does not accept @db.")
    if selected_database is not None and args.database is not None:
        raise KPassError("Cannot combine @db with --database.")

    profile = resolve_database_profile(file_config, selected_database)
    profile_config = config_from_profile(file_config, selected_database or file_config.default_database) if profile else None

    database = args.database or os.environ.get("KEEPASS_DB_PATH") or (profile_config.database if profile_config else None) or DEFAULT_DB_PATH
    password_file = args.password_file or os.environ.get("KPASS_PASSWORD_FILE") or (profile_config.password_file if profile_config else None)
    key_file = args.key_file or os.environ.get("KPASS_KEY_FILE") or (profile_config.key_file if profile_config else None)
    resolved_password = None if password_file else (profile_config.password if profile_config else None)

    ttl_override = env_cache_ttl()
    if args.cache_ttl is not None:
        cache_ttl = args.cache_ttl
    elif ttl_override is not None:
        cache_ttl = ttl_override
    elif profile_config:
        cache_ttl = profile_config.cache_ttl
    else:
        cache_ttl = DEFAULT_CACHE_TTL

    if args.no_cache is not None:
        no_cache = args.no_cache
    elif profile_config:
        no_cache = profile_config.no_cache
    else:
        no_cache = False

    return Config(
        database=database,
        password_file=password_file,
        password=resolved_password,
        key_file=key_file,
        cache_ttl=cache_ttl,
        no_cache=no_cache,
    )


def split_path(value: str) -> list[str]:
    normalized = normalize_path(value)
    return [part for part in normalized.split("/") if part] if normalized else []


def join_path(parts: Iterable[str]) -> str:
    return "/".join(part for part in parts if part)


def display_path(node) -> str:
    return join_path(node.path)


def read_password(password_file: str | None, database: str) -> str | None:
    if password_file:
        path = Path(password_file).expanduser()
        if not path.is_file():
            raise KPassError(f"Password file not found: {path}")
        lines = path.read_text(encoding="utf-8").splitlines()
        return lines[0] if lines else ""

    prompt = f"KeePass password for {database}: "
    return getpass.getpass(prompt)


def cache_enabled(config: Config | None = None, *, password_file: str | None = None, no_cache: bool | None = None, cache_ttl: int | None = None) -> bool:
    if password_file:
        return False
    if no_cache:
        return False
    if cache_ttl is not None and cache_ttl <= 0:
        return False
    return bool(os.environ.get("XDG_RUNTIME_DIR"))


def cache_file_path(database: str, key_file: str | None) -> Path | None:
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    if not runtime_dir:
        return None
    cache_key = hashlib.sha256(
        f"{Path(database).expanduser().resolve()}::{Path(key_file).expanduser().resolve() if key_file else ''}".encode("utf-8")
    ).hexdigest()
    cache_dir = Path(runtime_dir) / "kpass"
    cache_dir.mkdir(mode=0o700, parents=True, exist_ok=True)
    os.chmod(cache_dir, 0o700)
    return cache_dir / f"{cache_key}.json"


def load_cached_password(database: str, key_file: str | None) -> str | None:
    cache_file = cache_file_path(database, key_file)
    if cache_file is None or not cache_file.is_file():
        return None
    try:
        data = json.loads(cache_file.read_text(encoding="utf-8"))
    except Exception:
        cache_file.unlink(missing_ok=True)
        return None

    expires_at = int(data.get("expires_at", 0))
    password = data.get("password")
    if not isinstance(password, str) or expires_at <= int(time.time()):
        cache_file.unlink(missing_ok=True)
        return None
    return password


def store_cached_password(database: str, key_file: str | None, password: str, ttl: int) -> None:
    cache_file = cache_file_path(database, key_file)
    if cache_file is None:
        return
    payload = {
        "expires_at": int(time.time()) + ttl,
        "password": password,
    }
    cache_file.write_text(json.dumps(payload), encoding="utf-8")
    os.chmod(cache_file, 0o600)


def clear_cached_password(database: str, key_file: str | None) -> bool:
    cache_file = cache_file_path(database, key_file)
    if cache_file is None or not cache_file.exists():
        return False
    cache_file.unlink()
    return True


def clear_all_cached_passwords() -> int:
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    if not runtime_dir:
        return 0
    cache_dir = Path(runtime_dir) / "kpass"
    if not cache_dir.is_dir():
        return 0
    removed = 0
    for item in cache_dir.glob("*.json"):
        item.unlink(missing_ok=True)
        removed += 1
    return removed


def open_database_file(database: str, password_file: str | None, key_file: str | None) -> PyKeePass:
    database_path = Path(database).expanduser()
    if not database_path.is_file():
        raise KPassError(f"KeePass database not found: {database_path}")

    def try_open(password: str | None) -> PyKeePass:
        kwargs = {}
        if password is not None:
            kwargs["password"] = password
        if key_file:
            kwargs["keyfile"] = os.path.expanduser(key_file)
        return PyKeePass(str(database_path), **kwargs)

    cached_password = load_cached_password(str(database_path), key_file) if cache_enabled(password_file=password_file, cache_ttl=DEFAULT_CACHE_TTL) else None
    if cached_password is not None:
        try:
            return try_open(cached_password)
        except Exception:
            clear_cached_password(str(database_path), key_file)

    password = read_password(password_file, str(database_path))
    kwargs = {}
    if password is not None:
        kwargs["password"] = password
    if key_file:
        kwargs["keyfile"] = os.path.expanduser(key_file)

    try:
        kp = PyKeePass(str(database_path), **kwargs)
        if password is not None and cache_enabled(password_file=password_file, cache_ttl=DEFAULT_CACHE_TTL):
            store_cached_password(str(database_path), key_file, password, DEFAULT_CACHE_TTL)
        return kp
    except Exception as exc:  # pragma: no cover - pykeepass specifics
        raise KPassError(f"Failed to open KeePass database: {exc}") from exc


def open_database(config: Config) -> PyKeePass:
    database_path = Path(config.database).expanduser()
    if not database_path.is_file():
        raise KPassError(f"KeePass database not found: {database_path}")

    def try_open(password: str | None) -> PyKeePass:
        kwargs = {}
        if password is not None:
            kwargs["password"] = password
        if config.key_file:
            kwargs["keyfile"] = os.path.expanduser(config.key_file)
        return PyKeePass(str(database_path), **kwargs)

    cached_password = None
    if cache_enabled(config, password_file=config.password_file, no_cache=config.no_cache, cache_ttl=config.cache_ttl):
        cached_password = load_cached_password(str(database_path), config.key_file)
    if cached_password is not None:
        try:
            kp = try_open(cached_password)
            if config.cache_ttl > 0:
                store_cached_password(str(database_path), config.key_file, cached_password, config.cache_ttl)
            return kp
        except Exception:
            clear_cached_password(str(database_path), config.key_file)

    password = config.password if config.password is not None else read_password(config.password_file, str(database_path))
    try:
        kp = try_open(password)
        if (
            password is not None
            and cache_enabled(config, password_file=config.password_file, no_cache=config.no_cache, cache_ttl=config.cache_ttl)
        ):
            store_cached_password(str(database_path), config.key_file, password, config.cache_ttl)
        return kp
    except Exception as exc:  # pragma: no cover - pykeepass specifics
        raise KPassError(f"Failed to open KeePass database: {exc}") from exc


def sorted_entries(kp: PyKeePass):
    return sorted(kp.find_entries(recursive=True), key=lambda entry: display_path(entry).lower())


def sorted_groups(kp: PyKeePass):
    return sorted(
        (group for group in kp.find_groups(recursive=True) if group is not kp.root_group),
        key=lambda group: display_path(group).lower(),
    )


def unique_or_raise(matches: list, query: str, kind: str):
    if not matches:
        raise MatchError(f"{kind} not found: {query}")
    if len(matches) > 1:
        rendered = ", ".join(display_path(match) for match in matches[:8])
        suffix = " ..." if len(matches) > 8 else ""
        raise MatchError(f"Ambiguous {kind} '{query}': {rendered}{suffix}")
    return matches[0]


def resolve_entry(kp: PyKeePass, query: str):
    normalized = normalize_path(query)
    if not normalized:
        raise MatchError("Entry path cannot be empty.")

    entries = sorted_entries(kp)
    path_matches = [entry for entry in entries if display_path(entry) == normalized]
    if path_matches:
        return unique_or_raise(path_matches, query, "entry")

    title_matches = [entry for entry in entries if entry.title == normalized]
    if title_matches:
        return unique_or_raise(title_matches, query, "entry")

    partial_matches = [
        entry for entry in entries if normalized.lower() in display_path(entry).lower() or normalized.lower() in entry.title.lower()
    ]
    return unique_or_raise(partial_matches, query, "entry")


def find_entry_by_exact_path(kp: PyKeePass, path: str):
    normalized = normalize_path(path)
    if not normalized:
        return None
    return next((entry for entry in sorted_entries(kp) if display_path(entry) == normalized), None)


def apply_entry_fields(
    entry,
    *,
    username: str | None = None,
    url: str | None = None,
    notes: str | None = None,
    otp: str | None = None,
    replace_missing: bool = False,
) -> None:
    if replace_missing or username is not None:
        entry.username = username or ""
    if replace_missing or url is not None:
        entry.url = url or ""
    if replace_missing or notes is not None:
        entry.notes = notes or ""
    if replace_missing or otp is not None:
        entry.otp = otp or ""


def attachment_matches(entry, filename: str):
    return [attachment for attachment in entry.attachments if attachment.filename == filename]


def resolve_attachment(entry, filename: str):
    matches = attachment_matches(entry, filename)
    if not matches:
        raise KPassError(f"Attachment not found: {filename}")
    if len(matches) > 1:
        raise KPassError(f"Ambiguous attachment '{filename}'")
    return matches[0]


def resolve_group(kp: PyKeePass, query: str):
    normalized = normalize_path(query)
    if not normalized:
        return kp.root_group

    groups = sorted_groups(kp)
    path_matches = [group for group in groups if display_path(group) == normalized]
    if path_matches:
        return unique_or_raise(path_matches, query, "group")

    name_matches = [group for group in groups if group.name == normalized]
    if name_matches:
        return unique_or_raise(name_matches, query, "group")

    partial_matches = [
        group for group in groups if normalized.lower() in display_path(group).lower() or normalized.lower() in group.name.lower()
    ]
    return unique_or_raise(partial_matches, query, "group")


def ensure_group(kp: PyKeePass, group_path: str):
    current = kp.root_group
    current_path = []
    for part in split_path(group_path):
        current_path.append(part)
        wanted = join_path(current_path)
        existing = next((group for group in current.subgroups if display_path(group) == wanted), None)
        current = existing or kp.add_group(current, part)
    return current


def unique_entry_path(kp: PyKeePass, group_path: str, title: str, suffix: str = "merged") -> str:
    base_path = join_path([group_path, title]) if group_path else title
    if all(display_path(entry) != base_path for entry in sorted_entries(kp)):
        return base_path

    if suffix:
        candidate_title = f"{title} ({suffix})"
        candidate_path = join_path([group_path, candidate_title]) if group_path else candidate_title
        index = 2
    else:
        candidate_title = f"{title} (2)"
        candidate_path = join_path([group_path, candidate_title]) if group_path else candidate_title
        index = 3

    known_paths = {display_path(entry) for entry in sorted_entries(kp)}
    while candidate_path in known_paths:
        if suffix:
            candidate_title = f"{title} ({suffix} {index})"
        else:
            candidate_title = f"{title} ({index})"
        candidate_path = join_path([group_path, candidate_title]) if group_path else candidate_title
        index += 1
    return candidate_path


def prompt_secret(prompt: str, confirm: bool = False) -> str:
    first = getpass.getpass(prompt)
    if not confirm:
        return first
    second = getpass.getpass(f"Repeat {prompt}")
    if first != second:
        raise KPassError("Values do not match.")
    return first


def read_secret_from_stdin() -> str:
    value = sys.stdin.read()
    if value.endswith("\n"):
        value = value[:-1]
    return value


def editor_argv(explicit_editor: str | None = None) -> list[str]:
    editor = explicit_editor or os.environ.get("VISUAL") or os.environ.get("EDITOR") or shutil.which("vi") or shutil.which("nano")
    if not editor:
        raise KPassError("No editor found. Set $VISUAL or $EDITOR.")
    try:
        argv = shlex.split(editor)
    except ValueError as exc:
        raise KPassError(f"Invalid editor command: {exc}") from exc
    if not argv:
        raise KPassError("Editor command cannot be empty.")
    return argv


def serialize_entry_for_edit(entry) -> str:
    lines = [
        "# Edit the fields below. Use 'mv' to change the full path.",
        f"# Path: {display_path(entry)}",
        f"title: {entry.title or ''}",
        f"username: {entry.username or ''}",
        f"password: {entry.password or ''}",
        f"url: {entry.url or ''}",
        f"otp: {entry.otp or ''}",
        "---",
    ]
    notes = entry.notes or ""
    if notes:
        lines.append(notes)
    return "\n".join(lines) + "\n"


def parse_edited_entry(text: str) -> dict[str, str]:
    values = {field: "" for field in EDITABLE_ENTRY_FIELDS}
    header_lines: list[str] = []
    notes_lines: list[str] = []
    in_notes = False

    for line in text.splitlines():
        if in_notes:
            notes_lines.append(line)
            continue
        if line.startswith("#"):
            continue
        if line == "---":
            in_notes = True
            continue
        if line.strip():
            header_lines.append(line)

    if not in_notes:
        raise KPassError("Edited entry is missing the '---' notes separator.")

    seen: set[str] = set()
    for line in header_lines:
        if ":" not in line:
            raise KPassError(f"Invalid edit line: {line}")
        key, value = line.split(":", 1)
        normalized_key = key.strip().lower()
        if normalized_key not in values:
            raise KPassError(f"Unsupported edit field: {normalized_key}")
        if normalized_key in seen:
            raise KPassError(f"Duplicate edit field: {normalized_key}")
        values[normalized_key] = value.lstrip(" ")
        seen.add(normalized_key)

    missing = [field for field in EDITABLE_ENTRY_FIELDS if field not in seen]
    if missing:
        raise KPassError(f"Edited entry is missing field(s): {', '.join(missing)}")

    values["notes"] = "\n".join(notes_lines)
    return values


def edit_entry_in_editor(entry, explicit_editor: str | None = None) -> dict[str, str]:
    with tempfile.NamedTemporaryFile("w", encoding="utf-8", prefix="kpass-edit-", suffix=".txt", delete=False) as handle:
        temp_path = Path(handle.name)
        os.chmod(temp_path, 0o600)
        handle.write(serialize_entry_for_edit(entry))

    try:
        command = editor_argv(explicit_editor) + [str(temp_path)]
        result = subprocess.run(command, check=False)
        if result.returncode != 0:
            raise KPassError(f"Editor exited with status {result.returncode}.")
        return parse_edited_entry(temp_path.read_text(encoding="utf-8"))
    finally:
        temp_path.unlink(missing_ok=True)


def password_charset(args: argparse.Namespace) -> str:
    groups = []
    if args.lower:
        groups.append(string.ascii_lowercase)
    if args.upper:
        groups.append(string.ascii_uppercase)
    if args.digits:
        groups.append(string.digits)
    if args.symbols:
        groups.append("!@#$%^&*()-_=+[]{}:,.?")

    if not groups:
        groups = [string.ascii_lowercase, string.ascii_uppercase, string.digits, "!@#$%^&*()-_=+[]{}:,.?"]

    charset = "".join(groups)
    if not charset:
        raise KPassError("Empty password charset.")
    return charset


def generate_password(length: int, *, lower: bool, upper: bool, digits: bool, symbols: bool) -> str:
    if length <= 0:
        raise KPassError("Password length must be positive.")

    args = argparse.Namespace(lower=lower, upper=upper, digits=digits, symbols=symbols)
    charset = password_charset(args)

    required_sets = []
    if lower:
        required_sets.append(string.ascii_lowercase)
    if upper:
        required_sets.append(string.ascii_uppercase)
    if digits:
        required_sets.append(string.digits)
    if symbols:
        required_sets.append("!@#$%^&*()-_=+[]{}:,.?")

    if required_sets and length < len(required_sets):
        raise KPassError("Password length is shorter than the number of required character groups.")

    password_chars = [secrets.choice(group) for group in required_sets]
    while len(password_chars) < length:
        password_chars.append(secrets.choice(charset))
    secrets.SystemRandom().shuffle(password_chars)
    return "".join(password_chars)


def select_password(args: argparse.Namespace, *, prompt: str, confirm: bool) -> str:
    provided = [
        args.password is not None,
        bool(args.password_stdin),
        bool(args.generate),
    ]
    if sum(provided) > 1:
        raise KPassError("Choose only one of --password, --password-stdin, or --generate.")

    if args.password is not None:
        return args.password
    if args.password_stdin:
        return read_secret_from_stdin()
    if args.generate:
        return generate_password(args.length, lower=args.lower, upper=args.upper, digits=args.digits, symbols=args.symbols)
    return prompt_secret(prompt, confirm=confirm)


def get_entry_attribute(entry, attribute: str) -> str:
    attribute = attribute.lower()
    if attribute in {"title", "name"}:
        return entry.title or ""
    if attribute in {"username", "user", "login"}:
        return entry.username or ""
    if attribute in {"password", "pass"}:
        return entry.password or ""
    if attribute == "url":
        return entry.url or ""
    if attribute == "notes":
        return entry.notes or ""
    if attribute == "path":
        return display_path(entry)
    if attribute == "otp":
        return generate_totp(entry.otp)
    if attribute in {"totp", "code"}:
        return generate_totp(entry.otp)
    raise KPassError(f"Unsupported attribute: {attribute}")


def parse_otpauth(uri: str):
    parsed = urlparse(uri)
    if parsed.scheme != "otpauth":
        raise KPassError("OTP value is not an otpauth URI.")
    params = parse_qs(parsed.query)
    secret = params.get("secret", [""])[0]
    if not secret:
        raise KPassError("OTP URI does not contain a secret.")
    digits = int(params.get("digits", ["6"])[0])
    period = int(params.get("period", ["30"])[0])
    algorithm = params.get("algorithm", ["SHA1"])[0].upper()
    return secret, digits, period, algorithm


def generate_totp(uri: str | None, *, now: int | None = None) -> str:
    if not uri:
        raise KPassError("Entry does not contain OTP data.")

    secret, digits, period, algorithm = parse_otpauth(uri)
    if algorithm not in {"SHA1", "SHA256", "SHA512"}:
        raise KPassError(f"Unsupported OTP algorithm: {algorithm}")

    normalized_secret = secret.upper()
    padding = "=" * ((8 - len(normalized_secret) % 8) % 8)
    key = base64.b32decode(normalized_secret + padding, casefold=True)

    timestamp = int(time.time() if now is None else now)
    counter = timestamp // period
    digestmod = getattr(hashlib, algorithm.lower())
    payload = counter.to_bytes(8, "big")
    digest = hmac.new(key, payload, digestmod).digest()
    offset = digest[-1] & 0x0F
    code = int.from_bytes(digest[offset : offset + 4], "big") & 0x7FFFFFFF
    return str(code % (10**digits)).zfill(digits)


def clipboard_backend() -> str:
    if shutil.which("wl-copy") and shutil.which("wl-paste"):
        return "wl"
    if shutil.which("xclip"):
        return "xclip"
    raise KPassError("No clipboard backend found. Install wl-clipboard or xclip.")


def picker_backend() -> list[str]:
    if shutil.which("fzf"):
        return ["fzf", "--select-1", "--exit-0"]
    raise KPassError("No picker backend found. Install fzf.")


def spawn_clear_clipboard(backend: str, timeout: int, expected: str) -> None:
    if timeout <= 0:
        return
    subprocess.Popen(
        [sys.executable, os.path.realpath(__file__), "__clear-clipboard", backend, str(timeout), expected],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        stdin=subprocess.DEVNULL,
        start_new_session=True,
    )


def clipboard_read(backend: str) -> str:
    if backend == "wl":
        result = subprocess.run(["wl-paste", "--no-newline"], capture_output=True, text=True, check=True)
        return result.stdout
    if backend == "xclip":
        result = subprocess.run(
            ["xclip", "-o", "-selection", "clipboard"],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.stdout
    raise KPassError(f"Unsupported clipboard backend: {backend}")


def clipboard_clear(backend: str) -> None:
    if backend == "wl":
        subprocess.run(["wl-copy", "--clear"], check=True)
        return
    if backend == "xclip":
        subprocess.run(["xclip", "-selection", "clipboard"], input="", text=True, check=True)
        return
    raise KPassError(f"Unsupported clipboard backend: {backend}")


def copy_to_clipboard(value: str, timeout: int) -> None:
    backend = clipboard_backend()
    if backend == "wl":
        subprocess.run(["wl-copy", "--sensitive"], input=value, text=True, check=True)
    else:
        subprocess.run(["xclip", "-selection", "clipboard"], input=value, text=True, check=True)
    spawn_clear_clipboard(backend, timeout, value)


def pick_entry_path(paths: list[str], query: str | None = None, *, launcher: bool = False) -> str:
    if not paths:
        raise KPassError("No entries found.")

    command = picker_backend()
    if query:
        command.extend(["-q", query])

    result = subprocess.run(
        command,
        input="\n".join(paths) + "\n",
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode not in {0, 1}:
        stderr = result.stderr.strip()
        raise KPassError(f"Picker exited with status {result.returncode}: {stderr or 'unknown error'}")

    selected = result.stdout.strip()
    if not selected:
        raise KPassError("No entry selected.")
    return selected


def clear_clipboard_after_timeout(backend: str, timeout: int, expected: str) -> int:
    time.sleep(timeout)
    try:
        current = clipboard_read(backend)
        if current == expected:
            clipboard_clear(backend)
    except Exception:
        return 1
    return 0


def format_entry(entry) -> str:
    otp_state = "yes" if entry.otp else "no"
    lines = [
        f"Path: {display_path(entry)}",
        f"Title: {entry.title or ''}",
        f"UserName: {entry.username or ''}",
        f"URL: {entry.url or ''}",
        f"Notes: {entry.notes or ''}",
        f"TOTP: {otp_state}",
    ]
    return "\n".join(lines)


def build_tree(paths: list[str]) -> dict[str, dict]:
    tree: dict[str, dict] = {}
    for path in paths:
        current = tree
        for part in split_path(path):
            current = current.setdefault(part, {})
    return tree


def render_tree(paths: list[str], root_label: str) -> str:
    lines = [root_label]
    tree = build_tree(paths)

    def walk(node: dict[str, dict], prefix: str) -> None:
        items = sorted(node.items(), key=lambda item: item[0].lower())
        for index, (name, child) in enumerate(items):
            is_last = index == len(items) - 1
            connector = "└── " if is_last else "├── "
            lines.append(f"{prefix}{connector}{name}")
            next_prefix = prefix + ("    " if is_last else "│   ")
            walk(child, next_prefix)

    walk(tree, "")
    return "\n".join(lines)


def replace_entry_data(target_kp: PyKeePass, target_entry, source_entry) -> None:
    target_entry.username = source_entry.username or ""
    target_entry.password = source_entry.password or ""
    target_entry.url = source_entry.url or ""
    target_entry.notes = source_entry.notes or ""
    target_entry.otp = source_entry.otp or ""
    target_entry.tags = list(source_entry.tags or [])

    for key in list(target_entry.custom_properties.keys()):
        target_entry.delete_custom_property(key)
    for key, value in source_entry.custom_properties.items():
        target_entry.set_custom_property(key, value)

    for attachment in list(target_entry.attachments):
        attachment.delete()
    for attachment in source_entry.attachments:
        binary_id = target_kp.add_binary(attachment.binary)
        target_entry.add_attachment(binary_id, attachment.filename)


def import_entry(target_kp: PyKeePass, source_entry, destination_path: str):
    destination_parts = split_path(destination_path)
    destination_group = ensure_group(target_kp, join_path(destination_parts[:-1]))
    title = destination_parts[-1]
    created = target_kp.add_entry(
        destination_group,
        title,
        source_entry.username or "",
        source_entry.password or "",
        url=source_entry.url or None,
        notes=source_entry.notes or None,
        otp=source_entry.otp or None,
        tags=list(source_entry.tags or []),
        force_creation=True,
    )
    for key, value in source_entry.custom_properties.items():
        created.set_custom_property(key, value)
    for attachment in source_entry.attachments:
        binary_id = target_kp.add_binary(attachment.binary)
        created.add_attachment(binary_id, attachment.filename)
    return created


def clone_entry(target_kp: PyKeePass, source_entry, destination_path: str):
    return import_entry(target_kp, source_entry, destination_path)


def cmd_ls(args: argparse.Namespace, kp: PyKeePass) -> int:
    base_group = resolve_group(kp, args.group) if args.group else kp.root_group
    prefix = display_path(base_group)

    if args.groups:
        groups = [
            group
            for group in sorted_groups(kp)
            if not prefix or display_path(group).startswith(prefix + "/") or display_path(group) == prefix
        ]
        for group in groups:
            print(display_path(group))
        return 0

    entries = [
        entry
        for entry in sorted_entries(kp)
        if not prefix or display_path(entry).startswith(prefix + "/") or display_path(entry) == prefix
    ]
    paths = [display_path(entry) for entry in entries]
    if args.flat:
        for path in paths:
            print(path)
        return 0

    root_label = prefix if prefix else "Password Store"
    print(render_tree(paths, root_label))
    return 0


def cmd_search(args: argparse.Namespace, kp: PyKeePass) -> int:
    fields = args.field or ["path", "title"]
    needle = args.term.lower() if args.ignore_case else args.term
    matched_paths = []

    for entry in sorted_entries(kp):
        haystacks = []
        for field in fields:
            if field == "otp":
                haystacks.append(entry.otp or "")
            elif field == "path":
                haystacks.append(display_path(entry))
            elif field == "title":
                haystacks.append(entry.title or "")
            elif field == "username":
                haystacks.append(entry.username or "")
            elif field == "password":
                haystacks.append(entry.password or "")
            elif field == "url":
                haystacks.append(entry.url or "")
            elif field == "notes":
                haystacks.append(entry.notes or "")

        if args.ignore_case:
            matched = any(needle in haystack.lower() for haystack in haystacks)
        else:
            matched = any(needle in haystack for haystack in haystacks)

        if matched:
            matched_paths.append(display_path(entry))

    if args.flat:
        for path in matched_paths:
            print(path)
        return 0

    print(render_tree(matched_paths, f"Search: {args.term}"))
    return 0


def cmd_get(args: argparse.Namespace, kp: PyKeePass) -> int:
    entry = resolve_entry(kp, args.entry)
    if args.field:
        for field in args.field:
            print(get_entry_attribute(entry, field))
    else:
        print(format_entry(entry))
    return 0


def cmd_copy(args: argparse.Namespace, kp: PyKeePass) -> int:
    entry = resolve_entry(kp, args.entry)
    value = get_entry_attribute(entry, args.field)
    copy_to_clipboard(value, args.timeout)
    print(f"Copied {args.field} for {display_path(entry)} to clipboard")
    return 0


def cmd_attach_ls(args: argparse.Namespace, kp: PyKeePass) -> int:
    entry = resolve_entry(kp, args.entry)
    for attachment in sorted(entry.attachments, key=lambda item: item.filename.lower()):
        print(attachment.filename)
    return 0


def cmd_attach_add(args: argparse.Namespace, kp: PyKeePass) -> int:
    entry = resolve_entry(kp, args.entry)
    source_path = Path(args.file).expanduser()
    if not source_path.is_file():
        raise KPassError(f"Attachment file not found: {source_path}")

    file_size = source_path.stat().st_size
    if file_size >= LARGE_ATTACHMENT_WARNING_BYTES:
        size_mib = file_size / (1024 * 1024)
        print(
            f"Warning: attachment '{source_path.name}' is {size_mib:.1f} MiB and will increase the KeePass database size.",
            file=sys.stderr,
        )

    attachment_name = args.name or source_path.name
    existing = attachment_matches(entry, attachment_name)
    if existing and not args.force:
        raise KPassError(f"Attachment already exists: {attachment_name}. Use --force to replace it.")
    for attachment in existing:
        attachment.delete()

    binary_id = kp.add_binary(source_path.read_bytes())
    entry.add_attachment(binary_id, attachment_name)
    kp.save()
    print(f"Added attachment {attachment_name} to {display_path(entry)}")
    return 0


def cmd_attach_remove(args: argparse.Namespace, kp: PyKeePass) -> int:
    entry = resolve_entry(kp, args.entry)
    attachment = resolve_attachment(entry, args.filename)
    attachment.delete()
    kp.save()
    print(f"Removed attachment {args.filename} from {display_path(entry)}")
    return 0


def cmd_attach_extract(args: argparse.Namespace, kp: PyKeePass) -> int:
    entry = resolve_entry(kp, args.entry)
    attachment = resolve_attachment(entry, args.filename)

    output_path = Path(args.output).expanduser() if args.output else Path(attachment.filename)
    if output_path.exists() and output_path.is_dir():
        output_path = output_path / attachment.filename
    if output_path.exists() and not args.force:
        raise KPassError(f"Output file already exists: {output_path}. Use --force to overwrite it.")

    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_bytes(attachment.binary)
    print(output_path)
    return 0


def cmd_pick(args: argparse.Namespace, kp: PyKeePass) -> int:
    selected_path = pick_entry_path([display_path(entry) for entry in sorted_entries(kp)], args.query)
    entry = resolve_entry(kp, selected_path)

    if args.action == "get":
        if args.field:
            print(get_entry_attribute(entry, args.field))
        else:
            print(format_entry(entry))
        return 0
    if args.action == "copy":
        field = args.field or "password"
        value = get_entry_attribute(entry, field)
        copy_to_clipboard(value, args.timeout)
        print(f"Copied {field} for {selected_path} to clipboard")
        return 0
    if args.action == "edit":
        edit_args = argparse.Namespace(
            entry=selected_path,
            editor=None,
            rename=None,
            username=None,
            url=None,
            notes=None,
            otp=None,
            clear=None,
            password=None,
            password_stdin=False,
            generate=False,
            lower=False,
            upper=False,
            digits=False,
            symbols=False,
            length=24,
        )
        return cmd_edit(edit_args, kp)

    raise KPassError(f"Unsupported pick action: {args.action}")


def cmd_insert(args: argparse.Namespace, kp: PyKeePass) -> int:
    target_path = normalize_path(args.entry)
    if not target_path:
        raise KPassError("Entry path cannot be empty.")

    existing_entry = find_entry_by_exact_path(kp, target_path)
    if existing_entry is not None and not args.force:
        raise KPassError(f"Entry already exists: {target_path}")

    password = select_password(args, prompt="Entry password: ", confirm=True)
    if existing_entry is not None:
        existing_entry.password = password
        apply_entry_fields(
            existing_entry,
            username=args.username,
            url=args.url,
            notes=args.notes,
            otp=args.otp,
            replace_missing=True,
        )
    else:
        parent = ensure_group(kp, join_path(split_path(target_path)[:-1]))
        title = split_path(target_path)[-1]
        entry = kp.add_entry(
            parent,
            title,
            args.username or "",
            password,
            url=args.url or None,
            notes=args.notes or None,
            otp=args.otp or None,
            force_creation=False,
        )
        apply_entry_fields(
            entry,
            username=args.username,
            url=args.url,
            notes=args.notes,
            otp=args.otp,
            replace_missing=True,
        )
    kp.save()
    print(target_path)
    return 0


def cmd_edit(args: argparse.Namespace, kp: PyKeePass) -> int:
    entry = resolve_entry(kp, args.entry)
    changed = False
    direct_changes_requested = any(
        [
            args.rename is not None,
            args.username is not None,
            args.url is not None,
            args.notes is not None,
            args.otp is not None,
            bool(args.clear),
            args.password is not None,
            bool(args.password_stdin),
            bool(args.generate),
        ]
    )

    if args.editor and direct_changes_requested:
        raise KPassError("--editor cannot be combined with direct field updates.")

    if not direct_changes_requested:
        edited = edit_entry_in_editor(entry, args.editor)
        original_values = {
            "title": entry.title or "",
            "username": entry.username or "",
            "password": entry.password or "",
            "url": entry.url or "",
            "otp": entry.otp or "",
            "notes": entry.notes or "",
        }
        for field, value in edited.items():
            if original_values[field] != value:
                setattr(entry, field, value)
                changed = True
    else:
        if args.rename:
            entry.title = args.rename
            changed = True
        if args.username is not None:
            entry.username = args.username
            changed = True
        if args.url is not None:
            entry.url = args.url
            changed = True
        if args.notes is not None:
            entry.notes = args.notes
            changed = True
        if args.otp is not None:
            entry.otp = args.otp
            changed = True
        if args.clear:
            for field in args.clear:
                if field == "username":
                    entry.username = ""
                elif field == "password":
                    entry.password = ""
                elif field == "url":
                    entry.url = ""
                elif field == "notes":
                    entry.notes = ""
                elif field == "otp":
                    entry.otp = ""
                else:
                    raise KPassError(f"Unsupported clear field: {field}")
                changed = True

        if args.password is not None or args.password_stdin or args.generate:
            entry.password = select_password(args, prompt="New password: ", confirm=True)
            changed = True

    if not changed:
        raise KPassError("No changes requested.")

    kp.save()
    print(display_path(entry))
    return 0


def cmd_remove(args: argparse.Namespace, kp: PyKeePass) -> int:
    entry = resolve_entry(kp, args.entry)
    if not args.force:
        reply = input(f"Delete {display_path(entry)}? [y/N]: ").strip().lower()
        if reply not in {"y", "yes"}:
            raise KPassError("Aborted.")
    kp.delete_entry(entry)
    kp.save()
    return 0


def cmd_move(args: argparse.Namespace, kp: PyKeePass) -> int:
    entry = resolve_entry(kp, args.source)
    destination = normalize_path(args.destination)
    if not destination:
        raise KPassError("Destination path cannot be empty.")
    if any(display_path(candidate) == destination and candidate is not entry for candidate in sorted_entries(kp)) and not args.force:
        raise KPassError(f"Destination already exists: {destination}")

    destination_parts = split_path(destination)
    destination_group = ensure_group(kp, join_path(destination_parts[:-1]))
    if entry.group is not destination_group:
        kp.move_entry(entry, destination_group)
    entry.title = destination_parts[-1]
    kp.save()
    print(destination)
    return 0


def cmd_clone(args: argparse.Namespace, kp: PyKeePass) -> int:
    entry = resolve_entry(kp, args.source)
    destination = normalize_path(args.destination)
    if not destination:
        raise KPassError("Destination path cannot be empty.")
    if any(display_path(candidate) == destination for candidate in sorted_entries(kp)) and not args.force:
        raise KPassError(f"Destination already exists: {destination}")

    clone_entry(kp, entry, destination)
    kp.save()
    print(destination)
    return 0


def cmd_mkdir(args: argparse.Namespace, kp: PyKeePass) -> int:
    group_path = normalize_path(args.group)
    if not group_path:
        raise KPassError("Group path cannot be empty.")
    ensure_group(kp, group_path)
    kp.save()
    print(group_path)
    return 0


def cmd_generate(args: argparse.Namespace, kp: PyKeePass) -> int:
    target_path = normalize_path(args.entry)
    if not target_path:
        raise KPassError("Entry path cannot be empty.")

    entry = find_entry_by_exact_path(kp, target_path)
    if entry is None:
        parent = ensure_group(kp, join_path(split_path(target_path)[:-1]))
        title = split_path(target_path)[-1]
        entry = kp.add_entry(parent, title, "", "", force_creation=False)
        apply_entry_fields(
            entry,
            username=args.username,
            url=args.url,
            notes=args.notes,
            otp=args.otp,
            replace_missing=True,
        )
    elif not args.force:
        raise KPassError(f"Entry already exists: {target_path}. Use --force to replace its password.")
    else:
        apply_entry_fields(
            entry,
            username=args.username,
            url=args.url,
            notes=args.notes,
            otp=args.otp,
            replace_missing=False,
        )

    password = generate_password(args.length, lower=args.lower, upper=args.upper, digits=args.digits, symbols=args.symbols)
    entry.password = password
    kp.save()
    if args.copy:
        copy_to_clipboard(password, args.timeout)
        print(f"Generated new password for {display_path(entry)} and copied it to clipboard")
    else:
        print(display_path(entry))
    return 0


def cmd_merge(args: argparse.Namespace, kp: PyKeePass) -> int:
    target_db = Path(args.database).expanduser().resolve()
    source_db = Path(args.source_database).expanduser().resolve()
    if target_db == source_db:
        raise KPassError("Source and target database must be different.")

    source_kp = open_database_file(args.source_database, args.source_password_file, args.source_key_file)

    imported = 0
    overwritten = 0
    skipped = 0
    renamed = 0

    for source_entry in sorted_entries(source_kp):
        entry_path = display_path(source_entry)
        try:
            existing = resolve_entry(kp, entry_path)
            exact_match = display_path(existing) == entry_path
        except MatchError:
            existing = None
            exact_match = False

        if exact_match and existing is not None:
            if args.on_conflict == "error":
                raise KPassError(f"Merge conflict on entry: {entry_path}")
            if args.on_conflict == "skip":
                skipped += 1
                continue
            if args.on_conflict == "overwrite":
                replace_entry_data(kp, existing, source_entry)
                overwritten += 1
                continue
            if args.on_conflict == "rename":
                new_path = unique_entry_path(
                    kp,
                    join_path(split_path(entry_path)[:-1]),
                    split_path(entry_path)[-1],
                    suffix=args.rename_suffix,
                )
                import_entry(kp, source_entry, new_path)
                renamed += 1
                continue

        import_entry(kp, source_entry, entry_path)
        imported += 1

    kp.save()
    print(f"Imported: {imported}")
    print(f"Overwritten: {overwritten}")
    print(f"Skipped: {skipped}")
    print(f"Renamed: {renamed}")
    return 0


def password_source_description(profile: DatabaseProfile) -> str:
    if profile.password_file:
        return f"file:{profile.password_file}"
    if profile.password_database and profile.password_entry:
        return f"profile:{profile.password_database}:{profile.password_entry}"
    return "prompt"


def cmd_doctor(args: argparse.Namespace, _kp: PyKeePass | None = None) -> int:
    file_config: FileConfig = args._file_config
    config_path: Path = args._config_path

    if not file_config.databases:
        raise KPassError(f"No database profiles configured in {config_path}")

    print(f"Config: {config_path}")
    print(f"Default: {file_config.default_database}")

    issues = 0
    for profile_name in sorted(file_config.databases):
        profile = file_config.databases[profile_name]
        profile_issues: list[str] = []

        if not Path(profile.database).expanduser().is_file():
            profile_issues.append(f"database not found: {profile.database}")
        if profile.password_file and not Path(profile.password_file).expanduser().is_file():
            profile_issues.append(f"password file not found: {profile.password_file}")
        if profile.key_file and not Path(profile.key_file).expanduser().is_file():
            profile_issues.append(f"key file not found: {profile.key_file}")
        if profile.password_database and profile.password_database not in file_config.databases:
            profile_issues.append(f"password database profile not found: {profile.password_database}")

        if not profile_issues:
            try:
                config_from_profile(file_config, profile_name)
            except (KPassError, MatchError) as exc:
                profile_issues.append(str(exc))

        status = "OK" if not profile_issues else "ERROR"
        print(f"{status} {profile_name}: database={profile.database} password={password_source_description(profile)}")
        for issue in profile_issues:
            print(f"  - {issue}")
        issues += len(profile_issues)

    if issues:
        print(f"Doctor found {issues} issue(s)")
        return 1

    print("Doctor found no issues")
    return 0


def require_database_profile_name(name: str) -> str:
    normalized = name.strip()
    if not normalized:
        raise KPassError("Database profile name cannot be empty.")
    return normalized


def build_database_profile(
    name: str,
    database: str,
    password_file: str | None,
    password_database: str | None,
    password_entry: str | None,
    key_file: str | None,
    cache_ttl: int | None,
    no_cache: bool | None,
) -> DatabaseProfile:
    payload = {
        "database": database,
        "password_file": password_file,
        "password_database": password_database,
        "password_entry": password_entry,
        "key_file": key_file,
        "session_ttl": cache_ttl,
        "no_session": no_cache,
    }
    return parse_database_profile(name, payload, Path("<cli>"))


def cmd_db_ls(args: argparse.Namespace, _kp: PyKeePass | None = None) -> int:
    file_config: FileConfig = args._file_config

    if not file_config.databases:
        print("No database profiles configured")
        return 0

    if file_config.default_database:
        print(f"Default: {file_config.default_database}")
    for profile_name in sorted(file_config.databases):
        profile = file_config.databases[profile_name]
        marker = "*" if profile_name == file_config.default_database else " "
        print(f"{marker} {profile_name}: {profile.database} [{password_source_description(profile)}]")
    return 0


def cmd_db_add(args: argparse.Namespace, _kp: PyKeePass | None = None) -> int:
    file_config: FileConfig = args._file_config
    config_path: Path = args._config_path

    name = require_database_profile_name(args.name)
    if name in file_config.databases:
        raise KPassError(f"Database profile already exists: {name}")
    if args.profile_password_database is not None:
        source_name = require_database_profile_name(args.profile_password_database)
        if source_name == name:
            raise KPassError("Database profile cannot use itself as a password source.")
        if source_name not in file_config.databases:
            raise KPassError(f"Password database profile not found: {source_name}")
    else:
        source_name = None

    profile = build_database_profile(
        name,
        expand_path(args.database_path) or args.database_path,
        expand_path(args.profile_password_file),
        source_name,
        args.profile_password_entry,
        expand_path(args.profile_key_file),
        args.profile_cache_ttl,
        True if args.profile_no_cache else None,
    )

    databases = dict(file_config.databases)
    databases[name] = profile
    default_database = file_config.default_database or name
    if args.make_default:
        default_database = name

    write_file_config(config_path, FileConfig(default_database=default_database, databases=databases))
    print(f"Added database profile {name}")
    if default_database == name:
        print(f"Default database profile is now {name}")
    return 0


def cmd_db_rm(args: argparse.Namespace, _kp: PyKeePass | None = None) -> int:
    file_config: FileConfig = args._file_config
    config_path: Path = args._config_path

    name = require_database_profile_name(args.name)
    if name not in file_config.databases:
        raise KPassError(f"Database profile not found: {name}")
    if len(file_config.databases) == 1:
        raise KPassError("Cannot remove the last database profile.")

    databases = dict(file_config.databases)
    del databases[name]
    default_database = file_config.default_database
    switched_default = None
    if default_database == name:
        switched_default = sorted(databases)[0]
        default_database = switched_default

    for profile_name, profile in databases.items():
        if profile.password_database == name:
            raise KPassError(f"Cannot remove database profile '{name}' because '{profile_name}' depends on it for password lookup.")

    write_file_config(config_path, FileConfig(default_database=default_database, databases=databases))
    print(f"Removed database profile {name}")
    if switched_default is not None:
        print(f"Default database profile is now {switched_default}")
    return 0


def cmd_db_default(args: argparse.Namespace, _kp: PyKeePass | None = None) -> int:
    file_config: FileConfig = args._file_config
    config_path: Path = args._config_path

    if args.name is None:
        if file_config.default_database is None:
            raise KPassError("No default database configured.")
        print(file_config.default_database)
        return 0

    name = require_database_profile_name(args.name)
    if name not in file_config.databases:
        raise KPassError(f"Database profile not found: {name}")

    write_file_config(config_path, FileConfig(default_database=name, databases=dict(file_config.databases)))
    print(f"Default database profile is now {name}")
    return 0


def add_password_options(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--password", help="Use this password value directly.")
    parser.add_argument("--password-stdin", action="store_true", help="Read the password value from stdin.")
    parser.add_argument("-g", "--generate", action="store_true", help="Generate a password instead of prompting.")
    parser.add_argument("-L", "--length", type=int, default=24, help="Generated password length. Default: 24.")
    parser.add_argument("--lower", action="store_true", help="Require lowercase characters.")
    parser.add_argument("--upper", action="store_true", help="Require uppercase characters.")
    parser.add_argument("--digits", action="store_true", help="Require digits.")
    parser.add_argument("--symbols", action="store_true", help="Require symbols.")


def build_parser(file_config: FileConfig, config_path: Path) -> argparse.ArgumentParser:
    parser = KPassArgumentParser(
        prog="kpass",
        description="Entry-first CLI for KeePass database profiles.",
    )
    parser.add_argument(
        "--config",
        default=str(config_path),
        help=f"Path to the KPass TOML config file. Default: {config_path}.",
    )
    parser.add_argument(
        "--database",
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--password-file",
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--key-file",
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--session-ttl",
        "--cache-ttl",
        dest="cache_ttl",
        type=int,
        metavar="SECONDS",
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--no-session",
        "--no-cache",
        dest="no_cache",
        action="store_true",
        default=None,
        help=argparse.SUPPRESS,
    )

    subparsers = parser.add_subparsers(dest="command", required=True, parser_class=KPassArgumentParser)

    ls_parser = subparsers.add_parser("ls", help="List entries as a tree.", description="List entries in a group or in the whole database.")
    ls_parser.add_argument("group", nargs="?", help="Group to list. Defaults to the database root.")
    ls_parser.add_argument("--groups", action="store_true", help="List groups only.")
    ls_parser.add_argument("--flat", action="store_true", help="Print plain paths instead of a tree.")
    ls_parser.set_defaults(handler=cmd_ls)

    search_parser = subparsers.add_parser(
        "search",
        help="Find entries by name, path, or selected fields.",
        description="Find entries by path/title, or search inside selected fields.",
    )
    search_parser.add_argument("term", help="Text to search for.")
    search_parser.add_argument(
        "--field",
        action="append",
        choices=SEARCH_FIELD_CHOICES,
        help="Limit the search to one field. Can be used more than once. Default: path and title.",
    )
    search_parser.add_argument("-i", "--ignore-case", action="store_true", default=True, help="Search case-insensitively.")
    search_parser.add_argument("--flat", action="store_true", help="Print plain paths instead of a tree.")
    search_parser.set_defaults(handler=cmd_search)

    get_parser = subparsers.add_parser("get", help="Show one entry or one field.", description="Show the full entry or selected field values.")
    get_parser.add_argument("entry", help="Entry path or unique partial match.")
    get_parser.add_argument("-f", "--field", action="append", choices=ENTRY_FIELD_CHOICES, help="Show only selected fields, one per line.")
    get_parser.set_defaults(handler=cmd_get)

    copy_parser = subparsers.add_parser("copy", help="Copy a field to the clipboard.", description="Copy one entry field and clear the clipboard after a timeout.")
    copy_parser.add_argument("entry", help="Entry path or unique partial match.")
    copy_parser.add_argument("-f", "--field", choices=ENTRY_FIELD_CHOICES, default="password", help="Field to copy. Default: password.")
    copy_parser.add_argument("timeout", nargs="?", type=int, default=DEFAULT_CLIPBOARD_TIMEOUT, help="Seconds before clearing the clipboard. Default: 10.")
    copy_parser.set_defaults(handler=cmd_copy)

    attach_parser = subparsers.add_parser("attach", help="Manage entry attachments.", description="Add, list, remove, and extract attachment files stored in an entry.")
    attach_subparsers = attach_parser.add_subparsers(dest="attach_command", required=True)

    attach_ls_parser = attach_subparsers.add_parser("ls", help="List attachment files for an entry.")
    attach_ls_parser.add_argument("entry", help="Entry path or unique partial match.")
    attach_ls_parser.set_defaults(handler=cmd_attach_ls)

    attach_add_parser = attach_subparsers.add_parser("add", help="Attach a file to an entry.")
    attach_add_parser.add_argument("entry", help="Entry path or unique partial match.")
    attach_add_parser.add_argument("file", help="Local file to attach.")
    attach_add_parser.add_argument("--name", help="Stored attachment name. Defaults to the source filename.")
    attach_add_parser.add_argument("-f", "--force", action="store_true", help="Replace an existing attachment with the same name.")
    attach_add_parser.set_defaults(handler=cmd_attach_add)

    attach_remove_parser = attach_subparsers.add_parser("remove", help="Remove an attachment from an entry.")
    attach_remove_parser.add_argument("entry", help="Entry path or unique partial match.")
    attach_remove_parser.add_argument("filename", help="Stored attachment filename.")
    attach_remove_parser.set_defaults(handler=cmd_attach_remove)

    attach_extract_parser = attach_subparsers.add_parser("extract", help="Extract an attachment to a local file.")
    attach_extract_parser.add_argument("entry", help="Entry path or unique partial match.")
    attach_extract_parser.add_argument("filename", help="Stored attachment filename.")
    attach_extract_parser.add_argument("output", nargs="?", help="Output path. Defaults to ./<filename>.")
    attach_extract_parser.add_argument("-f", "--force", action="store_true", help="Overwrite an existing output file.")
    attach_extract_parser.set_defaults(handler=cmd_attach_extract)

    pick_parser = subparsers.add_parser("pick", help="Pick an entry interactively.", description="Choose an entry via fzf, then run get, copy, or edit.")
    pick_parser.add_argument("query", nargs="?", help="Initial picker query.")
    pick_parser.add_argument(
        "--action",
        choices=["get", "copy", "edit"],
        default="copy",
        help="Action to perform on the selected entry. Default: copy.",
    )
    pick_parser.add_argument(
        "-f",
        "--field",
        choices=ENTRY_FIELD_CHOICES,
        help="Field used by --action get or copy. Default: password for copy, full entry for get.",
    )
    pick_parser.add_argument("--timeout", type=int, default=DEFAULT_CLIPBOARD_TIMEOUT, help="Seconds before clearing the clipboard. Default: 10.")
    pick_parser.set_defaults(handler=cmd_pick)

    insert_parser = subparsers.add_parser("insert", help="Create a new entry.", description="Create an entry and any missing parent groups.")
    insert_parser.add_argument("entry", help="Destination entry path.")
    insert_parser.add_argument("-u", "--username", help="Username to store.")
    insert_parser.add_argument("--url", help="URL to store.")
    insert_parser.add_argument("--notes", help="Notes to store.")
    insert_parser.add_argument("--otp", help="otpauth:// URI to store as OTP data.")
    insert_parser.add_argument("-f", "--force", action="store_true", help="Allow replacing an existing entry at the same path.")
    add_password_options(insert_parser)
    insert_parser.set_defaults(handler=cmd_insert)

    edit_parser = subparsers.add_parser(
        "edit",
        help="Edit an existing entry.",
        description="Update fields directly or open the entry in $EDITOR.",
    )
    edit_parser.add_argument("entry", help="Entry path or unique partial match.")
    edit_parser.add_argument("--editor", help="Editor command to use instead of $VISUAL or $EDITOR.")
    edit_parser.add_argument("--rename", help="Rename the entry title only.")
    edit_parser.add_argument("-u", "--username", help="Set the username.")
    edit_parser.add_argument("--url", help="Set the URL.")
    edit_parser.add_argument("--notes", help="Set the notes.")
    edit_parser.add_argument("--otp", help="Set the otpauth:// URI.")
    edit_parser.add_argument("--clear", action="append", choices=["username", "password", "url", "notes", "otp"], help="Clear one field. Can be used more than once.")
    add_password_options(edit_parser)
    edit_parser.set_defaults(handler=cmd_edit)

    remove_parser = subparsers.add_parser("remove", help="Delete an entry.", description="Remove an entry from the database.")
    remove_parser.add_argument("entry", help="Entry path or unique partial match.")
    remove_parser.add_argument("-f", "--force", action="store_true", help="Delete without confirmation.")
    remove_parser.set_defaults(handler=cmd_remove)

    move_parser = subparsers.add_parser("move", help="Move or rename an entry.", description="Move an entry to another group or rename it by path.")
    move_parser.add_argument("source", help="Existing entry path.")
    move_parser.add_argument("destination", help="New entry path.")
    move_parser.add_argument("-f", "--force", action="store_true", help="Allow replacing an existing destination entry.")
    move_parser.set_defaults(handler=cmd_move)

    clone_parser = subparsers.add_parser("clone", help="Clone an entry.", description="Clone an entry to another path.")
    clone_parser.add_argument("source", help="Existing entry path.")
    clone_parser.add_argument("destination", help="New entry path.")
    clone_parser.add_argument("-f", "--force", action="store_true", help="Allow replacing an existing destination entry.")
    clone_parser.set_defaults(handler=cmd_clone)

    mkdir_parser = subparsers.add_parser("mkdir", help="Create a group path.", description="Create one or more missing groups.")
    mkdir_parser.add_argument("group", help="Group path to create.")
    mkdir_parser.set_defaults(handler=cmd_mkdir)

    generate_parser = subparsers.add_parser("generate", help="Generate and store a new password.", description="Create an entry or replace its password with a newly generated one.")
    generate_parser.add_argument("entry", help="Destination entry path.")
    generate_parser.add_argument("-u", "--username", help="Username to store.")
    generate_parser.add_argument("--url", help="URL to store.")
    generate_parser.add_argument("--notes", help="Notes to store.")
    generate_parser.add_argument("--otp", help="otpauth:// URI to store as OTP data.")
    generate_parser.add_argument("-f", "--force", action="store_true", help="Replace the password if the entry already exists.")
    generate_parser.add_argument("-L", "--length", type=int, default=24, help="Password length. Default: 24.")
    generate_parser.add_argument("--lower", action="store_true", help="Require lowercase characters.")
    generate_parser.add_argument("--upper", action="store_true", help="Require uppercase characters.")
    generate_parser.add_argument("--digits", action="store_true", help="Require digits.")
    generate_parser.add_argument("--symbols", action="store_true", help="Require symbols.")
    generate_parser.add_argument("--copy", action="store_true", help="Copy the new password to the clipboard.")
    generate_parser.add_argument("--clip", dest="copy", action="store_true", help=argparse.SUPPRESS)
    generate_parser.add_argument("timeout", nargs="?", type=int, default=DEFAULT_CLIPBOARD_TIMEOUT, help="Seconds before clearing the clipboard. Default: 10.")
    generate_parser.set_defaults(handler=cmd_generate)

    merge_parser = subparsers.add_parser("merge", help="Import entries from another database.", description="Merge another .kdbx into the current database.")
    merge_parser.add_argument("source_database", help="Source .kdbx database to import from.")
    merge_parser.add_argument("--source-password-file", help="Read the source database password from this file.")
    merge_parser.add_argument("--source-key-file", help="Optional key file for the source database.")
    merge_parser.add_argument(
        "--on-conflict",
        choices=["error", "skip", "overwrite", "rename"],
        default="rename",
        help="What to do when the target already has the same entry path. Default: rename.",
    )
    merge_parser.add_argument(
        "--rename-suffix",
        default="",
        help="Optional suffix for renamed duplicates. Empty means numeric names like '(2)'.",
    )
    merge_parser.set_defaults(handler=cmd_merge)

    doctor_parser = subparsers.add_parser("doctor", help="Validate config and profiles.", description="Check configured databases and password lookup chains.")
    doctor_parser.set_defaults(handler=cmd_doctor)

    db_parser = subparsers.add_parser("db", help="Manage database profiles.", description="List, add, remove, and update configured database profiles.")
    db_subparsers = db_parser.add_subparsers(dest="db_command", required=True)

    db_ls_parser = db_subparsers.add_parser("ls", help="List database profiles.")
    db_ls_parser.set_defaults(handler=cmd_db_ls)

    db_add_parser = db_subparsers.add_parser("add", help="Add a database profile.")
    db_add_parser.add_argument("name", help="Profile name.")
    db_add_parser.add_argument("database_path", help="Path to the .kdbx file.")
    db_add_parser.add_argument("--password-file", dest="profile_password_file", help="Read the database password from this file.")
    db_add_parser.add_argument("--password-database", dest="profile_password_database", help="Profile name of the database that stores this database password.")
    db_add_parser.add_argument("--password-entry", dest="profile_password_entry", help="Entry path inside --password-database that contains the password.")
    db_add_parser.add_argument("--key-file", dest="profile_key_file", help="Optional key file used to unlock the database.")
    db_add_parser.add_argument("--session-ttl", "--cache-ttl", dest="profile_cache_ttl", type=int, metavar="SECONDS", help="Session TTL for this profile.")
    db_add_parser.add_argument("--no-session", "--no-cache", dest="profile_no_cache", action="store_true", help="Disable session caching for this profile.")
    db_add_parser.add_argument("--default", dest="make_default", action="store_true", help="Make this profile the default.")
    db_add_parser.set_defaults(handler=cmd_db_add)

    db_rm_parser = db_subparsers.add_parser("rm", help="Remove a database profile.")
    db_rm_parser.add_argument("name", help="Profile name.")
    db_rm_parser.set_defaults(handler=cmd_db_rm)

    db_default_parser = db_subparsers.add_parser("default", help="Show or set the default database profile.")
    db_default_parser.add_argument("name", nargs="?", help="Profile name.")
    db_default_parser.set_defaults(handler=cmd_db_default)

    return parser


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    if argv and argv[0] == "__clear-clipboard":
        if len(argv) != 4:
            print("Invalid clipboard clear invocation.", file=sys.stderr)
            return 1
        _, backend, timeout, expected = argv
        return clear_clipboard_after_timeout(backend, int(timeout), expected)

    bootstrap = argparse.ArgumentParser(add_help=False)
    bootstrap.add_argument("--config")

    try:
        bootstrap_args, _ = bootstrap.parse_known_args(argv)
        file_config, config_path = load_file_config(bootstrap_args.config)
        parser = build_parser(file_config, config_path)
        argv, command, selected_database = extract_command_and_selector(argv)
    except KPassError as exc:
        print(str(exc), file=sys.stderr)
        return 1

    if command in LEGACY_COMMAND_HINTS:
        print(LEGACY_COMMAND_HINTS[command], file=sys.stderr)
        return 1

    if not argv:
        parser.print_help()
        return 0

    try:
        args = parser.parse_args(argv)
        args._file_config = file_config
        args._config_path = config_path
        if args.command in {"doctor", "db"}:
            if selected_database is not None:
                raise KPassError(f"Command '{args.command}' does not accept @db.")
            return args.handler(args, None)
        config = resolve_runtime_config(args, file_config, selected_database)
        args.database = config.database
        args.password_file = config.password_file
        args.key_file = config.key_file
        args.cache_ttl = config.cache_ttl
        args.no_cache = config.no_cache
        kp = open_database(config)
        return args.handler(args, kp)
    except (KPassError, MatchError) as exc:
        print(str(exc), file=sys.stderr)
        return 1
    except KeyboardInterrupt:
        print("Interrupted.", file=sys.stderr)
        return 130
    except Exception as exc:
        print(f"Unexpected error: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
